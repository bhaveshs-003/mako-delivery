# ─────────────────────────────────────────────────────────────
# Mako Governance Platform — environment template
# Copy to .env and fill in. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL="postgresql://USER@localhost:5432/mako_governance?schema=public"

# NextAuth — generate a strong secret: `openssl rand -hex 32`
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me"

# Audit log hash chain genesis (must NEVER change once data exists)
AUDIT_GENESIS_SEED="MAKO_GENESIS_BLOCK"

# Email (Resend) — optional in dev; notifications no-op if unset
RESEND_API_KEY=""
EMAIL_FROM="noreply@mako-platform.com"

# S3 / MinIO (file storage) — optional in dev
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_BUCKET="mako-governance"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
