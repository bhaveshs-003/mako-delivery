# ─────────────────────────────────────────────────────────────
# Mako Governance Platform — environment template
# Copy to .env and fill in. NEVER commit the real .env.
# See HOSTING.md for how to get each Supabase / Resend value.
# ─────────────────────────────────────────────────────────────

# ── Database (Supabase Postgres) ─────────────────────────────
# App runtime uses the POOLED connection (port 6543, ?pgbouncer=true).
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Migrations use the DIRECT connection (port 5432).
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ── NextAuth ─────────────────────────────────────────────────
NEXTAUTH_URL="https://your-app.vercel.app"   # http://localhost:3000 in dev
NEXTAUTH_SECRET="generate-with: openssl rand -hex 32"

# ── Audit log hash chain genesis (NEVER change once data exists) ─
AUDIT_GENESIS_SEED="MAKO_GENESIS_BLOCK"

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@yourdomain.com"          # must be a Resend-verified sender

# ── File storage (Supabase Storage — S3-compatible) ──────────
# Project Settings → Storage → S3 Connection.
S3_ENDPOINT="https://<ref>.storage.supabase.co/storage/v1/s3"
S3_REGION="<your-region>"                     # e.g. us-east-1 (match the project)
S3_BUCKET="mako-governance"                   # create this bucket in Supabase
S3_ACCESS_KEY_ID="<supabase-s3-access-key>"
S3_SECRET_ACCESS_KEY="<supabase-s3-secret-key>"
